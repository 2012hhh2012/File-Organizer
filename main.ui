  <property name="windowTitle">
   <string>File Organizer</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ================= MONOLITH CORE MASTER THEME ================= */
* {
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
    color: #e5e2e1;
}
QDialog {
    background-color: #0A0A0A;
    color: white;
}
QMainWindow, QWidget#centralwidget, QStackedWidget, QWidget#signin, QWidget#signup {
    background-color: #0A0A0A;
}
QWidget#main_app,
QWidget#dashboard_view,
QWidget#rules_view,
QWidget#tasks_view,
QWidget#archive_view,
QWidget#settings_view {
    background-color: #131313;
}

/* Typography Headings */
QLabel#lbl_signin_title, QLabel#lbl_signup_title {
    font-size: 26px; font-weight: bold; color: #FFFFFF; margin-bottom: 4px;
}
QLabel#lbl_dash_title,
QLabel#lbl_rules_page_title,
QLabel#lbl_tasks_page_title,
QLabel#lbl_archive_title,
QLabel#lbl_settings_title {
    font-size: 24px; font-weight: bold; color: #adc6ff;
}
QLabel#lbl_rules_page_sub,
QLabel#lbl_tasks_page_sub,
QLabel#lbl_archive_sub,
QLabel#lbl_settings_sub {
    font-size: 14px; color: #c2c6d6;
}
QLabel#lbl_ops_title, QLabel#lbl_rules_title, QLabel#lbl_new_rule_title {
    font-size: 16px; font-weight: bold; color: #e5e2e1;
}
QLabel#lbl_ops_sub, QLabel#lbl_new_rule_sub {
    font-size: 13px; color: #c2c6d6;
}

/* Inputs, Textboxes, and ComboBoxes */
QLineEdit, QComboBox {
    background-color: #1c1b1b;
    color: #FFFFFF;
    border: 1px solid #353534;
    border-radius: 6px;
    padding: 10px 12px;
    font-size: 13px;
}
QLineEdit:focus, QComboBox:focus {
    border: 1px solid #adc6ff;
}
QLineEdit[readOnly=&quot;true&quot;] {
    color: #8c909f;
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}
QComboBox QAbstractItemView {
    background-color: #1c1b1b;
    color: #FFFFFF;
    selection-background-color: #324974;
    border: 1px solid #353534;
}

/* Standard Buttons */
QPushButton {
    background-color: #adc6ff;
    color: #002e6a;
    border: none;
    border-radius: 6px;
    padding: 11px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton:hover { background-color: #d8e2ff; }
QPushButton:pressed { background-color: #4d8eff; }

/* Flat Text Links (Login/Signup) */
QPushButton#btn_go_signup, QPushButton#btn_go_signin {
    background-color: transparent; color: #d0bcff; font-weight: normal;
}
QPushButton#btn_go_signup:hover, QPushButton#btn_go_signin:hover {
    color: #FFFFFF; text-decoration: underline;
}

/* Forms and Cards */
QFrame#formFrame_signin, QFrame#formFrame_signup, QFrame#card_ops, QFrame#card_rules, QFrame#card_rules_table, QFrame#card_new_rule, QFrame#card_tasks_table,
QFrame#card_archive_table,
QFrame#card_settings_profile, QFrame#card_settings_password {
    background-color: #121212;
    border-radius: 12px;
    border: 1px solid #2a2a2a;
}

/* Sidebar Styling */
QFrame#sidebarFrame {
    background-color: #1c1b1b;
    border-right: 1px solid #2a2a2a;
}

/* Sidebar User Info */
QLabel#lbl_sidebar_username {
    font-size: 14px;
    font-weight: bold;
    color: #e5e2e1;
    padding: 8px 14px 4px 14px;
}

/* Sign Out Button */
QPushButton#btn_signout {
    background-color: #93000a;
    color: #ffb4ab;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 13px;
    font-weight: bold;
    text-align: left;
}
QPushButton#btn_signout:hover {
    background-color: #ffb4ab;
    color: #690005;
}
QPushButton#btn_signout:pressed {
    background-color: #ffdad6;
}

QPushButton#btn_nav_dash, QPushButton#btn_nav_rules, QPushButton#btn_nav_tasks, QPushButton#btn_nav_archive, QPushButton#btn_nav_settings {
    background-color: transparent;
    color: #c2c6d6;
    text-align: left;
    padding: 10px 14px;
    border-radius: 6px;
    font-weight: bold;
}
QPushButton#btn_nav_dash:hover, QPushButton#btn_nav_rules:hover, QPushButton#btn_nav_tasks:hover, QPushButton#btn_nav_archive:hover, QPushButton#btn_nav_settings:hover {
    background-color: #2a2a2a; color: #ffffff;
}
QPushButton#btn_nav_dash:checked, QPushButton#btn_nav_rules:checked, QPushButton#btn_nav_tasks:checked, QPushButton#btn_nav_archive:checked, QPushButton#btn_nav_settings:checked {
    background-color: #324974; color: #a2b8ea;
}

/* Action Buttons Specifics */
QPushButton#btn_browse_folder {
    background-color: #2a2a2a; color: #e5e2e1; border: 1px solid #353534;
}
QPushButton#btn_browse_folder:hover { background-color: #324974; color: #a2b8ea; }
QPushButton#btn_run_cleanup {
    background-color: #adc6ff; color: #00285d; font-size: 14px; padding: 14px; border-radius: 10px;
}
QPushButton#btn_run_cleanup:hover { background-color: #d8e2ff; }
QPushButton#btn_add_rule { background-color: #324974; color: #a2b8ea; }
QPushButton#btn_add_rule:hover { background-color: #4d8eff; color: #002e6a; }
QPushButton#btn_remove_rule { background-color: #2a2a2a; color: #ffb4ab; border: 1px solid #93000a; }
QPushButton#btn_remove_rule:hover { background-color: #93000a; color: #ffffff; }

QPushButton#btn_flush_logs {
    background-color: transparent; border: 1px solid #424754; color: #8c909f; padding: 8px 16px;
}
QPushButton#btn_flush_logs:hover {
    background-color: #2a2a2a; color: #e5e2e1;
}

/* Archive specific buttons */
QPushButton#btn_restore_archive {
    background: #2a2a2a;
    color: #adc6ff;
    border: 1px solid #353534;
}
QPushButton#btn_restore_archive:hover {
    background: #324974;
    color: white;
}
QPushButton#btn_empty_archive {
    background: #3a1a1a;
    color: #ffb4ab;
    border: 1px solid #93000a;
}
QPushButton#btn_empty_archive:hover {
    background: #93000a;
    color: white;
}

/* Settings page specific styles */
QPushButton#btn_update_username, QPushButton#btn_update_email {
    background-color: #324974;
    color: #a2b8ea;
    padding: 8px 16px;
    font-size: 12px;
}
QPushButton#btn_update_username:hover, QPushButton#btn_update_email:hover {
    background-color: #4d8eff;
    color: #002e6a;
}

QPushButton#btn_save_security {
    background-color: #adc6ff;
    color: #00285d;
    font-size: 16px;
    padding: 14px 32px;
    border-radius: 10px;
}
QPushButton#btn_save_security:hover {
    background-color: #d8e2ff;
}

QLabel#lbl_settings_footer_audit {
    font-size: 12px;
    color: #8c909f;
}
QPushButton#btn_privacy_policy, QPushButton#btn_session_logs {
    background-color: transparent;
    color: #8c909f;
    font-size: 12px;
    padding: 4px 8px;
    text-decoration: underline;
}
QPushButton#btn_privacy_policy:hover, QPushButton#btn_session_logs:hover {
    color: #adc6ff;
}

/* ---------- Additional inline styles moved here ---------- */
QLabel#lbl_side_appname {
    font-weight: bold;
    letter-spacing: 1px;
    color: #adc6ff;
    font-size: 15px;
}
QLabel#lbl_target_tag {
    font-size: 10px;
    font-weight: bold;
    color: #8c909f;
    letter-spacing: 1px;
}
QLabel#lbl_log_header {
    font-size: 11px;
    color: #8c909f;
    margin-top: 6px;
}
QLabel#lbl_preset {
    font-size: 12px;
    color: #8c909f;
    font-weight: bold;
}
QLabel#lbl_ext, QLabel#lbl_dest {
    font-size: 13px;
    color: #e5e2e1;
    font-weight: bold;
}
QPushButton#btn_save_rule {
    margin-top: 8px;
}
QLabel#lbl_profile_title, QLabel#lbl_password_title {
    font-size: 16px;
    font-weight: bold;
    color: #e5e2e1;
}
QLabel#lbl_username_label, QLabel#lbl_email_label,
QLabel#lbl_current_password, QLabel#lbl_new_password, QLabel#lbl_confirm_password {
    font-size: 13px;
    color: #c2c6d6;
}

/* Tables and Console Log */
QPlainTextEdit#txt_activity_log {
    background-color: #0e0e0e; color: #adc6ff; border: 1px solid #2a2a2a; border-radius: 8px; font-family: monospace; font-size: 11px;
}
QTableWidget {
    background-color: transparent; border: none; gridline-color: #2a2a2a;
}
QTableWidget::viewport {
    background-color: transparent;
}
QTableWidget::item {
    padding: 8px 4px; border-bottom: 1px solid #2a2a2a; color: #c2c6d6; font-size: 13px;
}
QTableWidget::item:selected {
    background-color: #324974; color: #ffffff;
}
QHeaderView::section {
    background-color: #1c1b1b; color: #8c909f; padding: 10px 6px; border: none; border-bottom: 1px solid #2a2a2a; font-weight: bold; font-size: 12px; text-align: left;
}

/* Remove button on full rules page */
QPushButton#btn_remove_rule_full {
    background-color: #2a2a2a;
    color: #ffb4ab;
    border: 1px solid #93000a;
    padding: 8px 16px;
    font-size: 12px;
}
QPushButton#btn_remove_rule_full:hover {
    background-color: #93000a;
    color: #ffffff;
}

/* Danger Zone - Delete Account button */
QPushButton#btn_delete_account {
    background-color: #93000a;
    color: #ffb4ab;
    border: 1px solid #93000a;
    padding: 12px 24px;
    font-size: 14px;
    font-weight: bold;
    border-radius: 6px;
}
QPushButton#btn_delete_account:hover {
    background-color: #ffb4ab;
    color: #690005;
}
QPushButton#btn_delete_account:pressed {
    background-color: #ffdad6;
}

/* Checkbox */
QCheckBox { font-size: 12px; spacing: 8px; }
QCheckBox::indicator { width: 16px; height: 16px; border-radius: 4px; border: 1px solid #8c909f; background: #131313; }
QCheckBox::indicator:checked { background: #adc6ff; border: 1px solid #adc6ff; }</string>

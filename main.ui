   <string>
/* Monolith Core Theme */
* {
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
}
QMainWindow, QWidget#centralwidget, QStackedWidget, QWidget#signin, QWidget#signup, QWidget#dashboard {
    background-color: #121212;
}
QLabel {
    color: #FFFFFF;
}
QLabel#lbl_signin_title, QLabel#lbl_signup_title {
    font-size: 28px;
    font-weight: bold;
    color: #FFFFFF;
    margin-bottom: 12px;
}
QLineEdit {
    background-color: #1A1A1A;
    color: #FFFFFF;
    border: 1px solid #6177A5;
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 14px;
}
QLineEdit:focus {
    border: 1px solid #3B82F6;
}
QPushButton {
    background-color: #3B82F6;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 12px;
    font-size: 14px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #6177A5;
}
QPushButton:pressed {
    background-color: #2563EB;
}
QPushButton#btn_go_signup, QPushButton#btn_go_signin {
    background-color: transparent;
    color: #8B5CF6;
    font-weight: normal;
}
QPushButton#btn_go_signup:hover, QPushButton#btn_go_signin:hover {
    color: #FFFFFF;
    text-decoration: underline;
}
QFrame#formFrame_signin, QFrame#formFrame_signup {
    background-color: #181818;
    border-radius: 12px;
    border: 1px solid #2A2A2A;
}
